      <column caption='Case Fatality Rate' datatype='real' default-format='p0.0%' name='[Calculation_1645154243801089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Cases]) &gt; 0 THEN&#13;&#10;SUM([Deaths]) / SUM([Cases])&#13;&#10;END' />
