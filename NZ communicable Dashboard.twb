      <column caption='Year Month' datatype='date' name='[Calculation_1645154243674112]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE(&#13;&#10;INT([Year]),&#13;&#10;INT([Month Number]),&#13;&#10;1&#13;&#10;)' />
